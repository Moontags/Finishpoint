SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=Finishpoint <no-reply@example.com>
QUOTE_RECIPIENT=kuljetus@finishpoint.fi
GOOGLE_MAPS_API_KEY=your-google-maps-server-api-key

# Optional fallback link: used when MobilePay API credentials are not configured
NEXT_PUBLIC_MOBILEPAY_PAYMENT_LINK=

# MobilePay API credentials (server-side only, no NEXT_PUBLIC_ prefix)
MOBILEPAY_CLIENT_ID=
MOBILEPAY_CLIENT_SECRET=
MOBILEPAY_SUBSCRIPTION_KEY_PRIMARY=
MOBILEPAY_SUBSCRIPTION_KEY_SECONDARY=

# Optional MobilePay API overrides
# MOBILEPAY_SUBSCRIPTION_KEY=
# MOBILEPAY_SCOPE=
# MOBILEPAY_TOKEN_AUTH_METHOD=client_secret_basic
# MOBILEPAY_TOKEN_URL=https://api.mobilepay.dk/merchant-authentication-openidconnect/connect/token
# MOBILEPAY_PAYMENTS_URL=https://api.mobilepay.dk/merchant/v1/payments
# MOBILEPAY_CURRENCY=EUR
# MOBILEPAY_RETURN_URL=https://example.com/kassa
# MOBILEPAY_CANCEL_URL=https://example.com/#quote
# MOBILEPAY_WEBHOOK_URL=https://example.com/api/mobilepay/webhook
# NEXT_PUBLIC_SITE_URL=https://example.com

# Optional Vipps eCom API credentials (server-side only)
# VIPPS_CLIENT_ID=
# VIPPS_CLIENT_SECRET=
# VIPPS_SUBSCRIPTION_KEY_PRIMARY=
# VIPPS_SUBSCRIPTION_KEY_SECONDARY=
# VIPPS_SUBSCRIPTION_KEY=
# VIPPS_MERCHANT_SERIAL_NUMBER=
# VIPPS_TOKEN_URL=https://api.vipps.no/accessToken/get
# VIPPS_PAYMENTS_URL=https://api.vipps.no/ecomm/v2/payments
# VIPPS_CURRENCY=NOK
# VIPPS_RETURN_URL=https://example.com/kassa
# VIPPS_CANCEL_URL=https://example.com/#quote
# VIPPS_CALLBACK_PREFIX=https://example.com/api/vipps
# VIPPS_WEBHOOK_AUTH_TOKEN=replace-with-long-random-secret